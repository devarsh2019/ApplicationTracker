# Local development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=application_tracker
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

CORS_ALLOWED_ORIGINS=http://localhost:4200

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_REMEMBER_ME_REFRESH_EXPIRATION_MS=2592000000

APP_SEED_DEMO_USER=true
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# --- Render + Neon (production) ---
# SPRING_PROFILES_ACTIVE=prod
# APP_SEED_DEMO_USER=false
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
#
# Neon (pick one style):
# DATABASE_URL=jdbc:postgresql://ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your-neon-password
#
# Or without DATABASE_URL:
# DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_JDBC_PARAMS=?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your-neon-password
