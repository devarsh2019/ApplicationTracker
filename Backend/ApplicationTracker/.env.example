# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=application_tracker
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# CORS (comma-separated for multiple origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_REMEMBER_ME_REFRESH_EXPIRATION_MS=2592000000

# App
APP_SEED_DEMO_USER=true
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Production example:
# SPRING_PROFILES_ACTIVE=prod
# APP_SEED_DEMO_USER=false
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
